# ─────────────────────────────────────────────────────────────────────────────
# WorkWise SaaS — Backend Environment Variable Template
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# AWS S3 — Payslip storage (optional: leave blank to use email-only mode) ─────
# Use a private bucket — never public. IAM role should have s3:PutObject,
# s3:GetObject, and s3:GeneratePresignedUrl on the payslips bucket only.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=af-south-1
AWS_PAYSLIPS_BUCKET=

# Django Core ─────────────────────────────────────────────────────────────────
# Generate a strong key with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_real_secret_key

# Set to False in production!
DJANGO_DEBUG=False

# Comma-separated list of domains your backend will be served from
DJANGO_ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com

# Set to True when you are behind a TLS termination proxy (e.g. Nginx, AWS ALB)
DJANGO_SECURE_SSL=False

# CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of trusted frontend origins (no trailing slash)
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# Clerk Authentication ────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_CHANGE_ME
CLERK_WEBHOOK_SECRET=whsec_CHANGE_ME
CLERK_ISSUER=https://your-clerk-issuer.example.com
CLERK_ALLOWED_ISSUERS=https://your-clerk-issuer.example.com
CLERK_JWKS_URL=https://your-clerk-issuer.example.com/.well-known/jwks.json
CLERK_AUDIENCE=api://workwise

# Safaricom Daraja M-Pesa Integration (B2C Payroll) ───────────────────────────
# Get your Consumer Key and Secret from: https://developer.safaricom.co.ke/MyApps
MPESA_ENABLED=False
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_daraja_consumer_key_here
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret_here
MPESA_SHORTCODE=600000
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=
MPESA_PASSKEY=
MPESA_STK_CALLBACK_URL=https://yourdomain.com/api/mpesa/stk-push-callback/
MPESA_B2C_RESULT_URL=https://yourdomain.com/api/mpesa/b2c/result/
MPESA_B2C_TIMEOUT_URL=https://yourdomain.com/api/mpesa/b2c/timeout/
