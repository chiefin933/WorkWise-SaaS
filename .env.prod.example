# ─────────────────────────────────────────────────────────────────────────────
# WorkWise SaaS — Production Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Instructions:
#   cp .env.prod.example .env.prod
#   Fill in every value. Never commit .env.prod to version control.
#
# docker-compose.prod.yml reads this file via: env_file: .env.prod
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET_KEY
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.workwise.co.ke,your-server-ip
DJANGO_SECURE_SSL=True

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Use Transaction Pooler (port 6543) for pgBouncer compatibility with Django
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_CONN_MAX_AGE=0
DB_DISABLE_SERVER_SIDE_CURSORS=True

# ── Redis (Celery broker + Django cache) ─────────────────────────────────────
# Internal Docker service name — matches docker-compose.prod.yml
REDIS_URL=redis://redis:6379/0

# ── CORS & Frontend ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://app.workwise.co.ke
FRONTEND_URL=https://app.workwise.co.ke

# ── Field-Level Encryption ────────────────────────────────────────────────────
# Generate: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# WARNING: Never change this after employees are created — encrypted fields become unreadable.
MASTER_ENCRYPTION_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY
FIELD_ENCRYPTION_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY

# ── Clerk Authentication ──────────────────────────────────────────────────────
CLERK_ISSUER=https://clerk.your-production-domain.com
CLERK_ALLOWED_ISSUERS=https://clerk.your-production-domain.com
CLERK_JWKS_URL=https://clerk.your-production-domain.com/.well-known/jwks.json
CLERK_SECRET_KEY=sk_live_REPLACE_WITH_CLERK_PRODUCTION_SECRET
CLERK_WEBHOOK_SECRET=whsec_REPLACE_WITH_CLERK_WEBHOOK_SECRET
# Leave blank to skip audience validation (recommended for most setups)
CLERK_AUDIENCE=

# ── Email (SMTP via Resend) ───────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=REPLACE_WITH_RESEND_API_KEY
DEFAULT_FROM_EMAIL=WorkWise HR <onboarding@resend.dev>

# ── M-Pesa Safaricom Daraja ───────────────────────────────────────────────────
MPESA_ENABLED=True
MPESA_ENVIRONMENT=production
MPESA_BASE_URL=https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=REPLACE_WITH_MPESA_CONSUMER_KEY
MPESA_CONSUMER_SECRET=REPLACE_WITH_MPESA_CONSUMER_SECRET
MPESA_INITIATOR_NAME=REPLACE_WITH_INITIATOR_NAME
MPESA_INITIATOR_PASSWORD=REPLACE_WITH_INITIATOR_PASSWORD
MPESA_B2C_SHORTCODE=REPLACE_WITH_B2C_SHORTCODE
MPESA_EXPRESS_SHORTCODE=REPLACE_WITH_PAYBILL_NUMBER
MPESA_PASSKEY=REPLACE_WITH_MPESA_PASSKEY
MPESA_SECURITY_CREDENTIAL=REPLACE_WITH_ENCRYPTED_SECURITY_CREDENTIAL
MPESA_B2C_RESULT_URL=https://api.workwise.co.ke/api/mpesa/b2c/result/
MPESA_B2C_TIMEOUT_URL=https://api.workwise.co.ke/api/mpesa/b2c/timeout/
MPESA_STK_CALLBACK_URL=https://api.workwise.co.ke/api/mpesa/stk-push-callback/
MPESA_CALLBACK_URL=https://api.workwise.co.ke/api/mpesa/stk-push-callback/

# ── AWS S3 (Payslip Storage) ──────────────────────────────────────────────────
# Optional — if not set, payslips are generated on-the-fly (no persistent storage)
AWS_PAYSLIPS_BUCKET=REPLACE_WITH_S3_BUCKET_NAME
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_KEY
AWS_S3_REGION_NAME=eu-central-1

# ── Backup Database (Supabase eu-west-1) ─────────────────────────────────────
# Switch DATABASE_URL to this value to failover to backup
BACKUP_DATABASE_URL=postgresql://postgres.[backup-project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require
