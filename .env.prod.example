# ─────────────────────────────────────────────────────────────────────────────
# WorkWise SaaS — Production Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Instructions:
#   cp .env.prod.example .env.prod
#   Fill in every value below.  Never commit .env.prod to version control.
#
# SECURITY: All secrets must be rotated immediately if accidentally exposed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.workwise.co.ke,your-server-ip

# ── Database (Supabase PostgreSQL or self-hosted) ─────────────────────────────
# Use Supabase connection pooler URL (Transaction mode port 6543):
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Or use individual vars if not using DATABASE_URL:
# DB_HOST=
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=
# DB_SSLMODE=require

# ── Redis (Cache + Celery Broker) ─────────────────────────────────────────────
# Docker Compose internal:
REDIS_URL=redis://redis:6379/0
# External Redis (e.g. Upstash):
# REDIS_URL=rediss://default:[password]@[host]:6380/0

# ── CORS (Frontend domain) ───────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://app.workwise.co.ke

# ── Frontend URL (used in email invite links) ─────────────────────────────────
FRONTEND_URL=https://app.workwise.co.ke

# ── Field-Level Encryption ────────────────────────────────────────────────────
# Generate a 32-byte key: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
MASTER_ENCRYPTION_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY

# ── Clerk Authentication ──────────────────────────────────────────────────────
CLERK_ISSUER=https://clerk.your-domain.com
CLERK_JWKS_URL=https://clerk.your-domain.com/.well-known/jwks.json
CLERK_SECRET_KEY=sk_live_REPLACE_WITH_CLERK_SECRET_KEY
CLERK_WEBHOOK_SECRET=whsec_REPLACE_WITH_CLERK_WEBHOOK_SECRET

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@workwise.co.ke
EMAIL_HOST_PASSWORD=REPLACE_WITH_APP_PASSWORD
DEFAULT_FROM_EMAIL=WorkWise HR <noreply@workwise.co.ke>

# ── M-Pesa Safaricom Daraja ───────────────────────────────────────────────────
MPESA_ENABLED=True
MPESA_ENVIRONMENT=production
MPESA_CONSUMER_KEY=REPLACE_WITH_MPESA_CONSUMER_KEY
MPESA_CONSUMER_SECRET=REPLACE_WITH_MPESA_CONSUMER_SECRET
MPESA_INITIATOR_NAME=REPLACE_WITH_INITIATOR_NAME
MPESA_INITIATOR_PASSWORD=REPLACE_WITH_INITIATOR_PASSWORD
MPESA_SHORTCODE=REPLACE_WITH_B2C_SHORTCODE
MPESA_B2C_SHORTCODE=REPLACE_WITH_B2C_SHORTCODE
MPESA_EXPRESS_SHORTCODE=REPLACE_WITH_PAYBILL_NUMBER
MPESA_PASSKEY=REPLACE_WITH_MPESA_PASSKEY
MPESA_SECURITY_CREDENTIAL=REPLACE_WITH_SECURITY_CREDENTIAL
MPESA_B2C_RESULT_URL=https://api.workwise.co.ke/api/mpesa/b2c/result/
MPESA_B2C_TIMEOUT_URL=https://api.workwise.co.ke/api/mpesa/b2c/timeout/
MPESA_STK_CALLBACK_URL=https://api.workwise.co.ke/api/mpesa/stk-push-callback/

# ── HTTPS / TLS ───────────────────────────────────────────────────────────────
# Set to True when Nginx is the TLS terminator (sends X-Forwarded-Proto: https)
DJANGO_SECURE_SSL=True
